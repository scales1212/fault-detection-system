from __future__ import annotations
import enum
from dataclasses import dataclass, field
from typing import Dict, List, Tuple


class FaultState(enum.Enum):
    UNDEFINED = 0
    PASS      = 1
    FAIL      = 2


@dataclass
class FaultId:
    id:          str
    numeric_id:  int
    device_type: str
    field:       str
    groups:      List[str]


# Key: (device_type, field_name)
FAULT_ID_REGISTRY: Dict[Tuple[str, str], FaultId] = {
{% for fid in fault_ids %}
    ("{{ fid.device_type }}", "{{ fid.field }}"): FaultId(
        id="{{ fid.id }}",
        numeric_id={{ fid.numeric_id }},
        device_type="{{ fid.device_type }}",
        field="{{ fid.field }}",
        groups={{ fid.groups | tojson }},
    ){% if not loop.last %},{% endif %}

{% endfor %}
}
